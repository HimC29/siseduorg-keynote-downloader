{
    "manifest_version": 3,
    "name": "sisedu.org Keynote Downloader",
    "version": "1.0.1",
    "description": "Download keynotes on sisedu.org as PDF easily with a click of a button.",
    "permissions": ["scripting", "activeTab", "tabs", "storage"],
    "icons": {
        "128": "media/logo.png"
    },
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": "media/logo.png",
        "default_title": "Keynote Downloader"
    },
    "background": {
        "service_worker": "background/service_worker.js"
    }
}
