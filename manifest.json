{
    "manifest_version": 3,
    "name": "sisedu.org Keynote Downloader",
    "version": "1.0.4",
    "description": "Download keynotes on sisedu.org as PDF easily with a click of a button.",
    "permissions": [
        "scripting",
        "activeTab",
        "storage"
    ],
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": "media/logo.png",
        "default_title": "Keynote Downloader"
    },
    "background": {
        "service_worker": "background/service_worker.js",
        "scripts": ["background/service_worker.js"]
    },
    "icons": {
        "128": "media/logo.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "himc.29z@gmail.com",
                        "data_collection_permissions": {
             "required": ["none"],
             "optional": []
            }
        }
    }
}
